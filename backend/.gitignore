# This file is not meant to be combined with the repository root .gitignore.
# Backend-specific ignores belong here; frontend/Next.js ignores stay in the root .gitignore.

# ---- Python ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# ---- Virtual environments ----
.venv/
venv/
env/
ENV/

# ---- Runtime data stores (regenerated on startup / at runtime) ----
data/*.sqlite3
data/*.json
data/*.db

# ---- Uploaded policy documents ----
uploads/policies/*
!uploads/policies/.gitkeep

# ---- Environment / secrets ----
.env
.env.*
*.local

# ---- Flask / instance ----
instance/
.webassets-cache

# ---- Testing / coverage ----
.pytest_cache/
.coverage
htmlcov/
.tox/

# ---- Editor / OS ----
.DS_Store
*.swp
.idea/
.vscode/
